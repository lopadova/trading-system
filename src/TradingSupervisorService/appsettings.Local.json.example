{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "_comment": "========================================",
  "_comment2": "Copy this file to appsettings.Local.json",
  "_comment3": "appsettings.Local.json is in .gitignore - your secrets stay private",
  "_comment4": "Only override values you need to change (all are optional)",
  "_comment5": "========================================",

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },

  "TradingMode": "paper",

  "Sqlite": {
    "SupervisorDbPath": "data/supervisor.db"
  },

  "Monitoring": {
    "IntervalSeconds": 60,
    "CpuThresholdPercent": 80.0,
    "RamThresholdPercent": 85.0,
    "DiskThresholdGb": 5.0
  },

  "OutboxSync": {
    "IntervalSeconds": 30,
    "BatchSize": 50,
    "InitialRetryDelaySeconds": 5,
    "MaxRetryDelaySeconds": 300,
    "MaxRetries": 10
  },

  "Cloudflare": {
    "WorkerUrl": "https://trading-alerts.YOUR-ACCOUNT.workers.dev",
    "ApiKey": "YOUR_CLOUDFLARE_API_KEY_HERE"
  },

  "IBKR": {
    "Host": "127.0.0.1",
    "PaperPort": 4002,
    "LivePort": 7497,
    "ClientId": 1
  },

  "Telegram": {
    "Enabled": false,
    "BotToken": "123456789:ABCdefGHIjklMNOpqrsTUVwxyz1234567890",
    "ChatId": 0,
    "MaxRetryAttempts": 3,
    "RetryDelaySeconds": 5,
    "MaxMessagesPerMinute": 20,
    "ProcessIntervalSeconds": 5
  },

  "LogReader": {
    "OptionsServiceLogPath": "logs/options-execution-.log",
    "IntervalSeconds": 30
  },

  "IvtsMonitor": {
    "Enabled": false,
    "IntervalSeconds": 900,
    "Symbol": "SPX",
    "IvrThresholdPercent": 80.0,
    "InvertedThresholdPercent": 5.0,
    "SpikeThresholdPercent": 20.0
  },

  "GreeksMonitor": {
    "Enabled": true,
    "IntervalSeconds": 60,
    "DeltaThreshold": 0.70,
    "GammaThreshold": 0.05,
    "ThetaThreshold": 50.0,
    "VegaThreshold": 100.0
  },

  "OptionsDb": {
    "OptionsDbPath": "data/options.db"
  },

  "Bots": {
    // Active bot type: "telegram", "discord", or "none"
    // - "telegram": Enable Telegram bot commands
    // - "discord": Enable Discord bot commands
    // - "none": Disable bot commands (alerts only)
    "ActiveBot": "none",

    // Cloudflare Worker webhook URL
    // Format: https://your-worker.workers.dev/api/bot
    "WebhookUrl": "https://trading-system.YOUR-ACCOUNT.workers.dev/api/bot",

    // Telegram bot token (from @BotFather)
    // Get it: Open Telegram → Search @BotFather → /newbot → Copy token
    "TelegramBotToken": "123456789:ABCdefGHIjklMNOpqrsTUVwxyz1234567890",

    // Discord bot token (from Discord Developer Portal)
    // Get it: https://discord.com/developers/applications → Your App → Bot → Reset Token
    "DiscordBotToken": "YOUR_DISCORD_BOT_TOKEN_HERE",

    // Discord application public key (for webhook signature verification)
    // Get it: https://discord.com/developers/applications → Your App → General Information → PUBLIC KEY
    "DiscordPublicKey": "YOUR_DISCORD_PUBLIC_KEY_HERE",

    // ⭐ WHITELIST: Comma-separated list of authorized user IDs
    //
    // 🎯 WHAT IS THIS?
    // Controls who can send commands to your bot (/status, /positions, /pnl, etc.)
    //
    // 🔒 SECURITY: If empty (""), NO ONE can use bot commands (maximum security)
    //
    // 📝 HOW TO GET YOUR USER ID:
    //
    // Telegram:
    //   1. Open Telegram → Search @userinfobot
    //   2. Send /start
    //   3. Copy the number (e.g., "123456789")
    //
    // Discord:
    //   1. Discord Settings → Advanced → Developer Mode ON
    //   2. Right-click your username → Copy User ID
    //   3. Copy the 18-digit number (e.g., "987654321098765432")
    //
    // 💡 EXAMPLES:
    //   Single user:  "123456789"
    //   Multi users:  "123456789,987654321,555666777"
    //   No access:    ""  (empty = nobody can use commands)
    //
    // ⚙️ HOW IT WORKS:
    //   1. You start the .NET service with Whitelist configured
    //   2. Service syncs user IDs to Worker's bot_whitelist table (D1)
    //   3. When a user sends /status, Worker checks if their ID is in bot_whitelist
    //   4. If YES → Command executed, response sent
    //   5. If NO → Command ignored (no response)
    //
    // 🔄 DYNAMIC MANAGEMENT:
    // After initial setup, you can add/remove users via D1 (no service restart):
    //   bunx wrangler d1 execute trading-db --remote --command="
    //   INSERT INTO bot_whitelist (user_id, bot_type, notes)
    //   VALUES ('123456789', 'telegram', 'Lorenzo - Owner');
    //   "
    //
    // 📚 FULL GUIDE: See docs/BOT_SETUP_GUIDE.md for detailed explanation
    "Whitelist": ""
  }
}
