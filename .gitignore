# ============================================================================
# Environment Variables & Secrets (CRITICAL - NEVER COMMIT)
# ============================================================================

# .NET secrets
# Per-environment appsettings overrides are gitignored — the .example
# templates with placeholder values ARE committed (see appsettings.*.json.example).
appsettings.Production.json
appsettings.Staging.json
appsettings.Live.json
appsettings.Local.json
**/secrets.json
UserSecrets/

# Phase 7.5 — Cloudflare Worker secrets staging area.
# scripts/provision-secrets.sh reads secrets/.env.<env> and feeds values
# to `bunx wrangler secret put`. The files contain cleartext tokens and
# MUST NEVER be committed. The three explicitly-whitelisted files document
# the directory shape for new operators. NOTE: we use `secrets/*` (not
# `secrets/`) because Git cannot re-include files from an excluded directory.
secrets/*
!secrets/.gitkeep
!secrets/README.md
!secrets/.env.example

# Node/Cloudflare secrets
.env
.env.local
.env.*.local
!.env.example
!.env.*.example
.dev.vars
!.dev.vars.example

# ============================================================================
# Database & Data Files (Local state - do not commit)
# ============================================================================

# SQLite databases — scope to repository root ONLY so source directories
# named `Data/` (e.g. src/SharedKernel/Data) don't get silently excluded.
# (Same class of bug as the /positions/, /trades/, /logs/ fix below — see
# commit 9c6f974.)
/data/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ============================================================================
# TRADING SYSTEM SPECIFIC - CRITICAL SECURITY
# ============================================================================

# Private strategies (NEVER commit - contains proprietary logic)
strategies/private/
strategies/*.json
!strategies/examples/

# Local trading data (root-level runtime data only — do NOT match source dirs
# like dashboard/src/components/positions/)
/positions/
/trades/
/logs/
*.log

