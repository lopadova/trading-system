# Dashboard Environment Variables (Development)
# Copy this file to .env.local and replace placeholder values

# Cloudflare Worker API endpoint
VITE_API_URL=https://trading-bot.padosoft.workers.dev

# API Key for Worker authentication (REQUIRED for production)
# Generate with: openssl rand -hex 32
# Add to D1 whitelist: see docs/GETTING_STARTED.md
VITE_API_KEY=your-generated-api-key-here

# Sentry DSN for dashboard error reporting. Leave empty to disable.
# Phase 7.3 — Sentry init is a no-op when this is unset.
VITE_SENTRY_DSN=

# Feature flags (optional)
VITE_ENABLE_EASYLANGUAGE_IMPORT=false
