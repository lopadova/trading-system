# Dashboard Environment Variables (Development)
# Copy this file to .env.local and replace placeholder values

# Anthropic Claude API Key for EasyLanguage → SDF conversion
# Get from: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_API_KEY

# Trading System API endpoint (optional, for future integration)
# VITE_API_BASE_URL=http://localhost:5000

# Feature flags
VITE_ENABLE_EASYLANGUAGE_IMPORT=true
