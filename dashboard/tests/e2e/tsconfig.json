{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "jsx": "preserve"
  },
  "include": ["**/*.ts", "../../playwright.config.ts"]
}
