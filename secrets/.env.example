# Cloudflare Worker secrets template.
# Copy to secrets/.env.staging OR secrets/.env.production, then:
#   ./scripts/provision-secrets.sh <env>
# to push each key to Cloudflare via `bunx wrangler secret put`.
#
# Format: KEY=VALUE per line. No quoting, no surrounding whitespace.
# Lines starting with # and blank lines are ignored.

# -------- Auth + core dependencies --------
# Shared secret used by the .NET Outbox sync + dashboard API calls. Must match
# appsettings.{Env}.json:Cloudflare:ApiKey on the .NET side (DPAPI-wrapped there).
API_KEY=REPLACE_WITH_LONG_RANDOM_STRING_64_CHARS

# Anthropic key used by the strategies-convert endpoint.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# -------- Telegram bot integration --------
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN

# -------- Discord bot integration (optional) --------
# If you are not using Discord, leave the Discord keys empty or omit them
# entirely — the Worker treats missing Discord secrets as "Discord disabled".
DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN
DISCORD_PUBLIC_KEY=REPLACE_WITH_DISCORD_PUBLIC_KEY

# Comma-separated list of Telegram / Discord user IDs allowed to invoke
# bot commands. Empty string means "nobody" (safer default).
BOT_WHITELIST=

# -------- Observability --------
# Optional: distinct Sentry DSN per environment so staging errors do not
# pollute the production issue inbox.
SENTRY_DSN=https://REPLACE_WITH_SENTRY_DSN@sentry.io/PROJECT_ID
