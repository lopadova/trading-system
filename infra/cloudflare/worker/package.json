{
  "name": "trading-system-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply trading-db --local",
    "migrate:prod": "wrangler d1 migrations apply trading-db",
    "test": "vitest run && vitest run -c vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.6.16",
    "@cloudflare/workers-types": "^4.20260418.1",
    "typescript": "^5.9.3",
    "vitest": "2.1.8",
    "wrangler": "^4.83.0"
  }
}
